<comment type="line">// Tests for a problem submitted by Ralph McArdell</comment>
<comment type="line">//</comment>
<comment type="line">// The static bool value should not need to be defined outside the</comment>
<comment type="line">// struct it is declared in - but when evaluating it in a deduced</comment>
<comment type="line">// context it appears to require the extra definition.</comment>
<comment type="line">// The issue was fixed by adding bool overloads to bypass the</comment>
<comment type="line">// templates that were there to deduce it.</comment>
<struct><template>template <parameter_list>&lt;<parameter><type><name>bool</name></type> <name>B</name></parameter>&gt;</parameter_list></template>
struct <name>is_true</name>
<block>{<public type="default">
    <decl_stmt><decl><type><specifier>static</specifier> <specifier>const</specifier> <name>bool</name></type> <name>value</name> <init>= <expr><name>B</name></expr></init></decl>;</decl_stmt>
</public>}</block>;</struct>

<macro><name>TEST_CASE</name><argument_list>( <argument><literal type="string">"(unimplemented) static bools can be evaluated"</literal></argument>, <argument><literal type="string">"[Tricky]"</literal></argument> )</argument_list></macro>
<block>{<block_content>
