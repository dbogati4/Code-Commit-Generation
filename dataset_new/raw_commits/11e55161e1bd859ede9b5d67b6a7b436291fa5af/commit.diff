+        .optArg( "<number of failures>", &Config::abortAfterX );
+
+    parser.addOption( "enables warnings" )
+        .shortName( "w")
+        .longName( "warn" )
+        .optArg( "<warning name>", &Config::addWarning );
+
+    std::cout << parser << std::endl;
 }
